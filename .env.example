# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (cards / Apple Pay / ACH)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Privy (crypto / embedded wallets)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# DoorDash CLI — https://github.com/doordash-oss/doordash-cli
# Default mock adapter (works on Windows). Real CLI: macOS Apple Silicon + waitlist.
DD_CLI_BIN=dd-cli
DD_CLI_MOCK=1
DD_CLI_USE_REAL=0
